{
	"name": "film-organizer",
	"version": "0.0.1",
	"description": "An electron desktop app to organize my analog photo scans",
	"main": "out/main/index.js",
	"scripts": {
		"dev": "electron-vite dev",
		"build": "electron-vite build",
		"preview": "electron-vite preview",
		"lint": "eslint --ext .ts,.tsx .",
		"test": "vitest",
		"test:watch": "vitest --watch",
		"dist": "npm run build && electron-builder --publish always"
	},
	"keywords": [],
	"author": {
		"name": "rodpepablo",
		"email": "rodpepablo@gmail.com"
	},
	"license": "GPLv3",
	"devDependencies": {
		"@types/jsdom": "^27.0.0",
		"@types/sortablejs": "^1.15.9",
		"@typescript-eslint/eslint-plugin": "^5.62.0",
		"@typescript-eslint/parser": "^5.62.0",
		"electron": "39.2.7",
		"electron-builder": "^26.8.1",
		"electron-vite": "^5.0.0",
		"eslint": "^8.57.1",
		"eslint-plugin-import": "^2.32.0",
		"typescript": "^5.9.3",
		"vitest": "^4.0.17",
		"vitest-mock-extended": "^3.1.0"
	},
	"dependencies": {
		"@iconify-json/mdi": "^1.2.3",
		"choo": "^7.1.0",
		"iconify-icon": "^3.0.2",
		"jsdom": "^27.4.0",
		"normalize.css": "^8.0.1",
		"sharp": "^0.34.5",
		"sortablejs": "^1.15.7",
		"uuid": "^13.0.0",
		"zod": "^4.3.6"
	},
	"build": {
		"appId": "com.rodpepablo.filmorganizer",
		"productName": "Film Organizer",

		"directories": {
			"output": "release"
		},

		"files": [
			"out/**/*",
			"node_modules/**/*",
			"package.json"
		],

		"asar": true,

		"asarUnpack": [
			"**/node_modules/sharp/**/*"
		],

		"mac": {
			"target": [
				"dmg"
			],
			"category": "public.app-category.photography"
		},

		"win": {
			"target": [
				"nsis"
			]
		},

		"linux": {
			"target": [
				"AppImage"
			]
		}
	}
}
